# =============================================================================
# CRM Backend Environment Variables
# =============================================================================

# Application
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
API_BASE_URL=https://api.yourcrm.com

# Security
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
API_KEY_SALT=your-api-key-salt-for-hashing
WEBHOOK_SECRET=your-webhook-signing-secret

# =============================================================================
# Supabase
# =============================================================================
SUPABASE_URL=https://vovppxpwuuhlbkihpaky.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_publishable_zX8P5u6tDXEsT35YCbsLQw_z7P8JSr1
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InZvdnBweHB3dXVobGJraWhwYWt5Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzMzMDU5MTIsImV4cCI6MjA4ODg4MTkxMn0.4jdSIki6QmSAoLA0ILs0jMJpAcZYLTCzebi_-cQ8VV8

# =============================================================================
# Redis
# =============================================================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_DB=0
# For Redis Cluster (comma-separated host:port pairs)
REDIS_CLUSTER_NODES=
# TLS for Redis (set to true in production)
REDIS_TLS=false

# =============================================================================
# AWS SES
# =============================================================================
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_SES_FROM_EMAIL=noreply@yourdomain.com
AWS_SES_FROM_NAME=Your Company
AWS_SES_DAILY_LIMIT=50000
AWS_SES_RATE_PER_SECOND=14

# =============================================================================
# SendGrid
# =============================================================================
SENDGRID_API_KEY=SG.your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=Your Company
SENDGRID_DAILY_LIMIT=100000
SENDGRID_RATE_PER_SECOND=100

# =============================================================================
# Mailgun
# =============================================================================
MAILGUN_API_KEY=key-your-mailgun-api-key
MAILGUN_DOMAIN=mg.yourdomain.com
MAILGUN_FROM_EMAIL=noreply@yourdomain.com
MAILGUN_FROM_NAME=Your Company
MAILGUN_DAILY_LIMIT=50000
MAILGUN_RATE_PER_SECOND=50
MAILGUN_REGION=us

# =============================================================================
# DKIM Signing
# =============================================================================
DKIM_DOMAIN=yourdomain.com
DKIM_KEY_SELECTOR=mail
# Private key (base64 encoded or path to file)
DKIM_PRIVATE_KEY_PATH=/etc/dkim/private.key
# Or inline (replace newlines with \n)
DKIM_PRIVATE_KEY=

# =============================================================================
# Email Queue Configuration
# =============================================================================
EMAIL_QUEUE_CONCURRENCY=50
CAMPAIGN_BATCH_SIZE=500
MAX_RETRIES=3
RETRY_DELAY_BASE=60000

# =============================================================================
# Per-Domain Throttling (emails per hour)
# =============================================================================
DOMAIN_THROTTLE_GMAIL=100
DOMAIN_THROTTLE_YAHOO=80
DOMAIN_THROTTLE_HOTMAIL=80
DOMAIN_THROTTLE_OUTLOOK=80
DOMAIN_THROTTLE_DEFAULT=200

# =============================================================================
# Bounce & Unsubscribe
# =============================================================================
UNSUBSCRIBE_BASE_URL=https://api.yourcrm.com/unsubscribe
TRACKING_PIXEL_BASE_URL=https://api.yourcrm.com/track/open
CLICK_TRACKING_BASE_URL=https://api.yourcrm.com/track/click

# =============================================================================
# Webhook URLs (for provider webhooks)
# =============================================================================
WEBHOOK_BASE_URL=https://api.yourcrm.com/webhooks

# =============================================================================
# CORS Configuration
# =============================================================================
# Comma-separated list of allowed origins for cross-origin requests
# Include all domains/ports your frontend runs on
# Supports wildcards: http://localhost:*, https://*.yourdomain.com
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:5173,https://yourdomain.com,https://app.yourdomain.com

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=info
LOG_PRETTY=false

# ── Google Calendar / Meet integration ──
# Option A: OAuth2 (any Google account) — connect via Settings > Integrations
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match the redirect registered in Google Cloud Console (the CRM settings page)
GOOGLE_REDIRECT_URI=http://localhost:3000/settings
# Optional: skip the UI flow by supplying a pre-obtained refresh token
GOOGLE_REFRESH_TOKEN=

# Option B: Workspace service account with domain-wide delegation (no UI needed)
# Paste the full service-account JSON on one line, and the user to impersonate
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_IMPERSONATE_EMAIL=sushilpradhan@primeosys.com

# Mailbox identity used for the CRM inbox/outbox
MAILBOX_FROM_NAME=Sushil Pradhan
MAILBOX_FROM_EMAIL=sushilpradhan@primeosys.com

# Base URL of the frontend (used to build OAuth redirect fallback)
APP_BASE_URL=http://localhost:3000
